# Copy this file to .env and fill in the values
# Then set these as environment variables in Railway / Render

# Shared secret between Next.js and this service (generate a strong random string)
AI_SERVICE_SECRET=your-secret-here

# Your OpenAI API key
OPENAI_API_KEY=sk-proj-...

# OpenAI model (default: gpt-image-1)
OPENAI_IMAGE_MODEL=gpt-image-1

# Image size — must match what the frontend expects
OPENAI_IMAGE_SIZE=1024x1536

# Restrict CORS to your Vercel domain (leave * for dev)
ALLOWED_ORIGIN=https://your-app.vercel.app

# Port (Railway/Render sets this automatically)
PORT=3001
